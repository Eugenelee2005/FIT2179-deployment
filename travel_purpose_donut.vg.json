{
  "width": 480,
  "height": 440,
  "background": "#ffffff",
  "title": {
    "text": "Visitor trips by travel purpose",
    "subtitle": "Use the year selector to compare the purpose mix.",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "params": [
    {
      "name": "selectedYear",
      "value": 2025,
      "bind": {
        "input": "select",
        "options": [
          2024,
          2025
        ],
        "name": "Year: "
      }
    }
  ],
  "data": {
    "url": "data/travel_purpose.csv"
  },
  "transform": [
    {
      "calculate": "selectedYear == 2024 ? datum.trips_2024 : datum.trips_2025",
      "as": "selected_trips"
    },
    {
      "calculate": "selectedYear == 2024 ? datum.share_2024_pct : datum.share_2025_pct",
      "as": "selected_share_pct"
    },
    {
      "calculate": "selectedYear == 2024 ? datum.spend_2024_m : datum.spend_2025_m",
      "as": "selected_spend_m"
    }
  ],
  "encoding": {
    "theta": {
      "field": "selected_trips",
      "type": "quantitative",
      "stack": true
    },
    "color": {
      "field": "purpose",
      "type": "nominal",
      "title": "Travel purpose",
      "scale": {
        "domain": [
          "Holiday",
          "Visiting friends and relatives",
          "Business",
          "Education",
          "Employment",
          "Other"
        ],
        "range": [
          "#0072b2",
          "#56b4e9",
          "#e69f00",
          "#cc79a7",
          "#6a51a3",
          "#999999"
        ]
      }
    },
    "tooltip": [
      {
        "field": "purpose",
        "type": "nominal",
        "title": "Purpose"
      },
      {
        "field": "selected_trips",
        "type": "quantitative",
        "title": "Trips ('000)",
        "format": ",.1f"
      },
      {
        "field": "selected_share_pct",
        "type": "quantitative",
        "title": "Share of trips",
        "format": ".1f"
      },
      {
        "field": "selected_spend_m",
        "type": "quantitative",
        "title": "Spend in Australia ($M)",
        "format": "$,.0f"
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "arc",
        "innerRadius": 92,
        "outerRadius": 175,
        "stroke": "#ffffff",
        "strokeWidth": 2
      }
    },
    {
      "transform": [
        {
          "filter": "datum.selected_share_pct >= 8"
        },
        {
          "calculate": "(datum.purpose == 'Visiting friends and relatives' ? 'VFR' : datum.purpose) + ' ' + format(datum.selected_share_pct, '.1f') + '%'",
          "as": "slice_label"
        }
      ],
      "mark": {
        "type": "text",
        "radius": 210,
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#17212b"
      },
      "encoding": {
        "text": {
          "field": "slice_label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "orient": "bottom",
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13,
      "columns": 2
    }
  }
}
