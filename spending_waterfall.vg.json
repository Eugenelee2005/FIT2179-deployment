{
  "width": 980,
  "height": 470,
  "background": "#ffffff",
  "title": {
    "text": "Drivers of visitor spending change",
    "subtitle": "Bars show how travel purposes contributed to the 2024-2025 spending increase.",
    "anchor": "middle",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "data": {
    "url": "data/waterfall_spending_change.csv"
  },
  "transform": [
    {
      "calculate": "min(datum.start, datum.end)",
      "as": "low"
    },
    {
      "calculate": "max(datum.start, datum.end)",
      "as": "high"
    },
    {
      "calculate": "datum.type == 'total' ? '$' + format(datum.end / 1000, '.1f') + 'B' : (datum.change >= 0 ? '+$' : '-$') + format(abs(datum.change), ',.0f') + 'M'",
      "as": "label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 2,
        "cornerRadiusTopRight": 2
      },
      "encoding": {
        "x": {
          "field": "component",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "sort_order"
          },
          "axis": {
            "labelAngle": -28,
            "labelLimit": 300,
            "labelFontSize": 12
          }
        },
        "y": {
          "field": "start",
          "type": "quantitative",
          "title": "Cumulative spend in Australia ($M)",
          "axis": {
            "format": "$,.0f",
            "gridColor": "#e5edf3",
            "labelFontSize": 12,
            "titleFontSize": 13
          }
        },
        "y2": {
          "field": "end"
        },
        "color": {
          "field": "type",
          "type": "nominal",
          "title": "Component type",
          "scale": {
            "domain": [
              "increase",
              "decrease",
              "total"
            ],
            "range": [
              "#009e73",
              "#d55e00",
              "#737373"
            ]
          }
        },
        "tooltip": [
          {
            "field": "component",
            "type": "nominal",
            "title": "Component"
          },
          {
            "field": "expenditure_2024",
            "type": "quantitative",
            "title": "2024 expenditure ($M)",
            "format": "$,.0f"
          },
          {
            "field": "expenditure_2025",
            "type": "quantitative",
            "title": "2025 expenditure ($M)",
            "format": "$,.0f"
          },
          {
            "field": "change",
            "type": "quantitative",
            "title": "Change ($M)",
            "format": "+$,.0f"
          },
          {
            "field": "percentage_change",
            "type": "quantitative",
            "title": "Percentage change",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -6,
        "font": "Arial",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#17212b"
      },
      "encoding": {
        "x": {
          "field": "component",
          "type": "nominal",
          "sort": {
            "field": "sort_order"
          }
        },
        "y": {
          "field": "high",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.component == 'Education'"
        },
        {
          "calculate": "'Largest driver: Education'",
          "as": "annotation"
        }
      ],
      "mark": {
        "type": "text",
        "dy": -30,
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#0072b2"
      },
      "encoding": {
        "x": {
          "field": "component",
          "type": "nominal",
          "sort": {
            "field": "sort_order"
          }
        },
        "y": {
          "field": "high",
          "type": "quantitative"
        },
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}
