{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 780,
  "height": 420,
  "background": "#ffffff",
  "title": {
    "text": "What drove the change in visitor spending?",
    "subtitle": "The waterfall chart shows how each travel purpose contributed to the difference between 2024 and 2025 spending.",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 20,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 12
  },
  "data": {
    "url": "data/waterfall_spending_change.csv"
  },
  "transform": [
    {
      "calculate": "min(datum.start, datum.end)",
      "as": "low"
    },
    {
      "calculate": "max(datum.start, datum.end)",
      "as": "high"
    },
    {
      "calculate": "datum.type == 'total' ? '$' + format(datum.end / 1000, '.1f') + 'B' : (datum.change >= 0 ? '+$' : '-$') + format(abs(datum.change), ',.0f') + 'M'",
      "as": "label"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusTopLeft": 2,
        "cornerRadiusTopRight": 2
      },
      "encoding": {
        "x": {
          "field": "component",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "sort_order"
          },
          "axis": {
            "labelAngle": -25,
            "labelLimit": 120
          }
        },
        "y": {
          "field": "start",
          "type": "quantitative",
          "title": "Cumulative spend in Australia ($M)",
          "axis": {
            "format": "$,.0f",
            "gridColor": "#e5edf3"
          }
        },
        "y2": {
          "field": "end"
        },
        "color": {
          "field": "type",
          "type": "nominal",
          "title": "Component type",
          "scale": {
            "domain": ["increase", "decrease", "total"],
            "range": ["#0072b2", "#d95f02", "#737373"]
          }
        },
        "tooltip": [
          {
            "field": "component",
            "type": "nominal",
            "title": "Component"
          },
          {
            "field": "expenditure_2024",
            "type": "quantitative",
            "title": "2024 expenditure ($M)",
            "format": "$,.0f"
          },
          {
            "field": "expenditure_2025",
            "type": "quantitative",
            "title": "2025 expenditure ($M)",
            "format": "$,.0f"
          },
          {
            "field": "change",
            "type": "quantitative",
            "title": "Change ($M)",
            "format": "+$,.0f"
          },
          {
            "field": "percentage_change",
            "type": "quantitative",
            "title": "Percentage change",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -6,
        "font": "Arial",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "#17212b"
      },
      "encoding": {
        "x": {
          "field": "component",
          "type": "nominal",
          "sort": {
            "field": "sort_order"
          }
        },
        "y": {
          "field": "high",
          "type": "quantitative"
        },
        "text": {
          "field": "label",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    }
  }
}

