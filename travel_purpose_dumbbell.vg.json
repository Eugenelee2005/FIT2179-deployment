{
  "width": 980,
  "height": 420,
  "background": "#ffffff",
  "title": {
    "text": "Travel purpose change from 2024 to 2025",
    "subtitle": "Connected dots compare visitor trips for each purpose.",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "data": {
    "url": "data/travel_purpose.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#9aa8b6",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "purpose",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "trips_2025",
            "order": "descending"
          },
          "axis": {
            "labelLimit": 260,
            "labelFontSize": 13
          }
        },
        "x": {
          "field": "trips_2024",
          "type": "quantitative",
          "title": "Visitor trips ('000)",
          "axis": {
            "format": ",.0f",
            "gridColor": "#e5edf3",
            "labelFontSize": 13,
            "titleFontSize": 13
          }
        },
        "x2": {
          "field": "trips_2025"
        },
        "tooltip": [
          {
            "field": "purpose",
            "type": "nominal",
            "title": "Purpose"
          },
          {
            "field": "trips_2024",
            "type": "quantitative",
            "title": "2024 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "trips_2025",
            "type": "quantitative",
            "title": "2025 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "trips_change_abs",
            "type": "quantitative",
            "title": "Absolute change ('000)",
            "format": "+,.1f"
          },
          {
            "field": "trips_change_pct",
            "type": "quantitative",
            "title": "Percentage change",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "fold": [
            "trips_2024",
            "trips_2025"
          ],
          "as": [
            "year_field",
            "trips"
          ]
        },
        {
          "calculate": "datum.year_field == 'trips_2024' ? '2024' : '2025'",
          "as": "year"
        }
      ],
      "mark": {
        "type": "circle",
        "size": 150,
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "field": "purpose",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "trips_2025",
            "order": "descending"
          },
          "axis": {
            "labelLimit": 260,
            "labelFontSize": 13
          }
        },
        "x": {
          "field": "trips",
          "type": "quantitative",
          "title": "Visitor trips ('000)",
          "axis": {
            "labelFontSize": 13,
            "titleFontSize": 13
          }
        },
        "color": {
          "field": "year",
          "type": "nominal",
          "title": "Year",
          "scale": {
            "domain": [
              "2024",
              "2025"
            ],
            "range": [
              "#a6cee3",
              "#0072b2"
            ]
          }
        },
        "tooltip": [
          {
            "field": "purpose",
            "type": "nominal",
            "title": "Purpose"
          },
          {
            "field": "trips_2024",
            "type": "quantitative",
            "title": "2024 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "trips_2025",
            "type": "quantitative",
            "title": "2025 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "trips_change_abs",
            "type": "quantitative",
            "title": "Absolute change ('000)",
            "format": "+,.1f"
          },
          {
            "field": "trips_change_pct",
            "type": "quantitative",
            "title": "Percentage change",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.purpose == 'Holiday'"
        },
        {
          "calculate": "'Largest increase: +' + format(datum.trips_change_abs, ',.0f') + 'k trips'",
          "as": "annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 14,
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#102033"
      },
      "encoding": {
        "y": {
          "field": "purpose",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "trips_2025",
            "order": "descending"
          }
        },
        "x": {
          "field": "trips_2025",
          "type": "quantitative"
        },
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 13,
      "titleFontSize": 13
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}
