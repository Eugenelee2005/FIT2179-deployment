{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "resize": true
  },
  "background": "#ffffff",
  "params": [
    {
      "name": "selectedView",
      "value": "Change 2024-2025",
      "bind": {
        "input": "radio",
        "options": ["Change 2024-2025", "2024 value", "2025 value"],
        "name": "View: "
      }
    },
    {
      "name": "selectedMetric",
      "value": "Expenditure ($M)",
      "bind": {
        "input": "radio",
        "options": ["Expenditure ($M)", "Visitor trips ('000)"],
        "name": "Measure: "
      }
    }
  ],
  "vconcat": [
    {
      "title": {
        "text": "International visitor activity by Australian state and territory",
        "subtitle": "Colour changes with the selected view and measure",
        "anchor": "start",
        "font": "Arial",
        "fontSize": 20,
        "subtitleFontSize": 12,
        "subtitleColor": "#5c6876",
        "offset": 12
      },
      "width": 820,
      "height": 500,
      "projection": {
        "type": "mercator"
      },
      "layer": [
        {
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "calculate": "'Data is not available for ' + datum.state_name",
              "as": "note"
            }
          ],
          "mark": {
            "type": "geoshape",
            "fill": "#edf2f6",
            "stroke": "#ffffff",
            "strokeWidth": 1
          },
          "encoding": {
            "tooltip": {
              "field": "note",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "lookup": "state_name",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "nights_2024": "number",
                      "nights_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number",
                      "exp_change_pct": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "nights_2024",
                  "nights_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": "isValid(datum.expenditure_2025_m)"
            },
            {
              "calculate": "selectedView == '2024 value' ? datum.expenditure_2024_m : (selectedView == '2025 value' ? datum.expenditure_2025_m : datum.expenditure_2024_m)",
              "as": "display_expenditure_m"
            },
            {
              "calculate": "selectedView == '2024 value' ? datum.trips_2024 : (selectedView == '2025 value' ? datum.trips_2025 : datum.trips_2024)",
              "as": "display_trips"
            },
            {
              "calculate": "selectedView == '2024 value' ? datum.nights_2024 : (selectedView == '2025 value' ? datum.nights_2025 : datum.nights_2024)",
              "as": "display_nights"
            },
            {
              "calculate": "datum.display_expenditure_m / datum.display_trips * 1000",
              "as": "avg_spend_per_trip"
            },
            {
              "calculate": "selectedView == 'Change 2024-2025' ? (selectedMetric == 'Expenditure ($M)' ? datum.exp_change_pct : (datum.trips_2025 - datum.trips_2024) / datum.trips_2024 * 100) : (selectedView == '2024 value' ? (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2024_m : datum.trips_2024) : (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2025_m : datum.trips_2025))",
              "as": "selected_value"
            }
          ],
          "params": [
            {
              "name": "stateSelection",
              "select": {
                "type": "point",
                "fields": ["state_name"],
                "on": "click",
                "clear": "dblclick"
              }
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "#ffffff",
            "strokeWidth": 1
          },
          "encoding": {
            "color": {
              "field": "selected_value",
              "type": "quantitative",
              "title": {
                "expr": "selectedView == 'Change 2024-2025' ? (selectedMetric == 'Expenditure ($M)' ? 'Change in expenditure (%)' : 'Change in trips (%)') : (selectedView == '2024 value' ? (selectedMetric == 'Expenditure ($M)' ? 'Expenditure 2024 ($M)' : 'Trips 2024 (000)') : (selectedMetric == 'Expenditure ($M)' ? 'Expenditure 2025 ($M)' : 'Trips 2025 (000)'))"
              },
              "scale": {
                "scheme": "tealblues"
              },
              "legend": {
                "orient": "right",
                "format": ",.0f"
              }
            },
            "stroke": {
              "condition": {
                "param": "stateSelection",
                "empty": false,
                "value": "#111827"
              },
              "value": "#ffffff"
            },
            "strokeWidth": {
              "condition": {
                "param": "stateSelection",
                "empty": false,
                "value": 3
              },
              "value": 1
            },
            "opacity": {
              "condition": {
                "param": "stateSelection",
                "value": 1
              },
              "value": 0.7
            },
            "tooltip": [
              {
                "field": "state_name",
                "type": "nominal",
                "title": "State/Territory"
              },
              {
                "field": "expenditure_2024_m",
                "type": "quantitative",
                "title": "2024 expenditure ($M)",
                "format": "$,.0f"
              },
              {
                "field": "expenditure_2025_m",
                "type": "quantitative",
                "title": "2025 expenditure ($M)",
                "format": "$,.0f"
              },
              {
                "field": "exp_change_pct",
                "type": "quantitative",
                "title": "% change in expenditure",
                "format": "+.1f"
              },
              {
                "field": "trips_2024",
                "type": "quantitative",
                "title": "2024 visitor trips ('000)",
                "format": ",.1f"
              },
              {
                "field": "trips_2025",
                "type": "quantitative",
                "title": "2025 visitor trips ('000)",
                "format": ",.1f"
              },
              {
                "field": "nights_2024",
                "type": "quantitative",
                "title": "2024 visitor nights ('000)",
                "format": ",.0f"
              },
              {
                "field": "nights_2025",
                "type": "quantitative",
                "title": "2025 visitor nights ('000)",
                "format": ",.0f"
              },
              {
                "field": "avg_spend_per_trip",
                "type": "quantitative",
                "title": "Avg spend per trip",
                "format": "$,.0f"
              },
              {
                "field": "selected_value",
                "type": "quantitative",
                "title": {
                  "expr": "selectedView + ' - ' + selectedMetric"
                },
                "format": ",.1f"
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {"state": "New South Wales",       "lon": 146.5, "lat": -32.8},
              {"state": "Victoria",              "lon": 144.5, "lat": -36.9},
              {"state": "Queensland",            "lon": 143.5, "lat": -22.5},
              {"state": "South Australia",       "lon": 135.5, "lat": -30.8},
              {"state": "Western Australia",     "lon": 121.0, "lat": -25.5},
              {"state": "Tasmania",              "lon": 147.0, "lat": -41.8},
              {"state": "Northern Territory",    "lon": 134.0, "lat": -20.5},
              {"state": "Australian Capital Territory", "lon": 149.2, "lat": -35.7}
            ]
          },
          "transform": [
            {
              "lookup": "state",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number",
                      "exp_change_pct": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": "isValid(datum.expenditure_2025_m)"
            },
            {
              "calculate": "selectedView == 'Change 2024-2025' ? (selectedMetric == 'Expenditure ($M)' ? datum.exp_change_pct : (datum.trips_2025 - datum.trips_2024) / datum.trips_2024 * 100) : (selectedView == '2024 value' ? (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2024_m : datum.trips_2024) : (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2025_m : datum.trips_2025))",
              "as": "selected_value"
            },
            {
              "calculate": "selectedView == 'Change 2024-2025' ? format(datum.selected_value, '+.1f') + '%' : format(datum.selected_value, ',.0f')",
              "as": "label_text"
            }
          ],
          "mark": {
            "type": "text",
            "fontSize": 11,
            "fontWeight": "bold",
            "font": "Arial",
            "stroke": "white",
            "strokeWidth": 2.5,
            "lineHeight": 12,
            "dx": 0,
            "dy": 0
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude": {"field": "lat", "type": "quantitative"},
            "text": {"field": "label_text", "type": "nominal"},
            "color": {"value": "#1e293b"},
            "opacity": {"value": 0.9}
          }
        }
      ]
    },
    {
      "hconcat": [
        {
          "title": {
            "text": "Selected State/Territory",
            "anchor": "start",
            "font": "Arial",
            "fontSize": 14
          },
          "width": 280,
          "height": 220,
          "projection": {
            "type": "mercator"
          },
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "lookup": "state_name",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "nights_2024": "number",
                      "nights_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number",
                      "exp_change_pct": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "nights_2024",
                  "nights_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": {
                "param": "stateSelection",
                "empty": false
              }
            },
            {
              "calculate": "selectedView == 'Change 2024-2025' ? (selectedMetric == 'Expenditure ($M)' ? datum.exp_change_pct : (datum.trips_2025 - datum.trips_2024) / datum.trips_2024 * 100) : (selectedView == '2024 value' ? (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2024_m : datum.trips_2024) : (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2025_m : datum.trips_2025))",
              "as": "selected_value"
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "#111827",
            "strokeWidth": 1.5
          },
          "encoding": {
            "color": {
              "field": "selected_value",
              "type": "quantitative",
              "scale": {
                "scheme": "tealblues"
              },
              "legend": null
            },
            "tooltip": [
              {
                "field": "state_name",
                "type": "nominal",
                "title": "State/Territory"
              },
              {
                "field": "selected_value",
                "type": "quantitative",
                "title": {
                  "expr": "selectedView + ' - ' + selectedMetric"
                },
                "format": ",.1f"
              }
            ]
          }
        },
        {
          "title": {
            "text": "Selected Value",
            "anchor": "start",
            "font": "Arial",
            "fontSize": 14
          },
          "width": 480,
          "height": 120,
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "lookup": "state_name",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": {
                "param": "stateSelection",
                "empty": false
              }
            },
            {
              "calculate": "selectedView == 'Change 2024-2025' ? (selectedMetric == 'Expenditure ($M)' ? datum.exp_change_pct : (datum.trips_2025 - datum.trips_2024) / datum.trips_2024 * 100) : (selectedView == '2024 value' ? (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2024_m : datum.trips_2024) : (selectedMetric == 'Expenditure ($M)' ? datum.expenditure_2025_m : datum.trips_2025))",
              "as": "selected_value"
            },
            {
              "calculate": "selectedMetric == 'Expenditure ($M)' ? 'Expenditure ($M)' : \"Visitor trips ('000)\"",
              "as": "metric_label"
            }
          ],
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 2
          },
          "encoding": {
            "x": {
              "field": "selected_value",
              "type": "quantitative",
              "title": null,
              "axis": {
                "format": ",.0f"
              }
            },
            "y": {
              "field": "state_name",
              "type": "nominal",
              "title": null
            },
            "color": {
              "value": "#0f766e"
            },
            "tooltip": [
              {
                "field": "state_name",
                "type": "nominal",
                "title": "State/Territory"
              },
              {
                "field": "metric_label",
                "type": "nominal",
                "title": "Metric"
              },
              {
                "field": "selected_value",
                "type": "quantitative",
                "title": "Value",
                "format": ",.1f"
              }
            ]
          }
        }
      ],
      "spacing": 40
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gradientLength": 220
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    }
  }
}
