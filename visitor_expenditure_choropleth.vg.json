{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "autosize": {
    "resize": true
  },
  "background": "#ffffff",
  "params": [
    {
      "name": "selectedView",
      "value": "% change expenditure",
      "bind": {
        "input": "radio",
        "options": [
          "% change expenditure",
          "2024 expenditure",
          "2025 expenditure",
          "2024 visitor trips",
          "2025 visitor trips"
        ],
        "name": "View: "
      }
    }
  ],
  "vconcat": [
    {
      "title": {
        "text": "International visitor activity by Australian state and territory",
        "subtitle": "Colour and labels update with the selected view",
        "anchor": "start",
        "font": "Arial",
        "fontSize": 20,
        "subtitleFontSize": 12,
        "subtitleColor": "#5c6876",
        "offset": 12
      },
      "width": 820,
      "height": 500,
      "projection": {
        "type": "mercator"
      },
      "layer": [
        {
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "calculate": "'Data is not available for ' + datum.state_name",
              "as": "note"
            }
          ],
          "mark": {
            "type": "geoshape",
            "fill": "#edf2f6",
            "stroke": "#ffffff",
            "strokeWidth": 1
          },
          "encoding": {
            "tooltip": {
              "field": "note",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "lookup": "state_name",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "nights_2024": "number",
                      "nights_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number",
                      "exp_change_pct": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "nights_2024",
                  "nights_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": "isValid(datum.expenditure_2025_m)"
            },
            {
              "calculate": "(datum.trips_2025 - datum.trips_2024) / datum.trips_2024 * 100",
              "as": "trips_change_pct"
            },
            {
              "calculate": "selectedView == '% change expenditure' ? datum.exp_change_pct : (selectedView == '2024 expenditure' ? datum.expenditure_2024_m : (selectedView == '2025 expenditure' ? datum.expenditure_2025_m : (selectedView == '2024 visitor trips' ? datum.trips_2024 : datum.trips_2025)))",
              "as": "selected_value"
            },
            {
              "calculate": "selectedView == '% change expenditure' ? (datum.selected_value < 0 ? '#e66101' : (datum.selected_value < 10 ? '#b8b8b8' : (datum.selected_value < 20 ? '#67a9cf' : '#2166ac'))) : (selectedView == '2024 expenditure' || selectedView == '2025 expenditure' ? (datum.selected_value < 1500 ? '#dbeafe' : (datum.selected_value < 4000 ? '#93c5fd' : (datum.selected_value < 8000 ? '#3b82f6' : '#1e3a8a'))) : (datum.selected_value < 500 ? '#ede9fe' : (datum.selected_value < 1500 ? '#c4b5fd' : (datum.selected_value < 3000 ? '#8b5cf6' : '#4c1d95'))))",
              "as": "map_color"
            },
            {
              "calculate": "selectedView == '% change expenditure' ? datum.exp_change_pct : (selectedView == '2024 visitor trips' || selectedView == '2025 visitor trips' ? datum.trips_change_pct : datum.exp_change_pct)",
              "as": "label_change_pct"
            },
            {
              "calculate": "datum.selected_value / 1000",
              "as": "selected_value_millions"
            },
            {
              "calculate": "datum.expenditure_2025_m / datum.trips_2025 * 1000",
              "as": "avg_spend_per_trip_2025"
            }
          ],
          "params": [
            {
              "name": "stateSelection",
              "select": {
                "type": "point",
                "fields": ["state_name"],
                "on": "click",
                "clear": "dblclick"
              }
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "#ffffff",
            "strokeWidth": 1
          },
          "encoding": {
            "color": {
              "field": "map_color",
              "type": "nominal",
              "scale": null,
              "legend": null
            },
            "stroke": {
              "condition": {
                "param": "stateSelection",
                "empty": false,
                "value": "#111827"
              },
              "value": "#ffffff"
            },
            "strokeWidth": {
              "condition": {
                "param": "stateSelection",
                "empty": false,
                "value": 3
              },
              "value": 1
            },
            "opacity": {
              "condition": {
                "param": "stateSelection",
                "value": 1
              },
              "value": 0.72
            },
            "tooltip": [
              {
                "field": "state_name",
                "type": "nominal",
                "title": "State/Territory"
              },
              {
                "field": "expenditure_2024_m",
                "type": "quantitative",
                "title": "2024 expenditure ($M)",
                "format": "$,.0f"
              },
              {
                "field": "expenditure_2025_m",
                "type": "quantitative",
                "title": "2025 expenditure ($M)",
                "format": "$,.0f"
              },
              {
                "field": "exp_change_pct",
                "type": "quantitative",
                "title": "% change in expenditure",
                "format": "+.1f"
              },
              {
                "field": "trips_2024",
                "type": "quantitative",
                "title": "2024 visitor trips ('000)",
                "format": ",.1f"
              },
              {
                "field": "trips_2025",
                "type": "quantitative",
                "title": "2025 visitor trips ('000)",
                "format": ",.1f"
              },
              {
                "field": "trips_change_pct",
                "type": "quantitative",
                "title": "% change in visitor trips",
                "format": "+.1f"
              },
              {
                "field": "nights_2025",
                "type": "quantitative",
                "title": "2025 visitor nights ('000)",
                "format": ",.0f"
              },
              {
                "field": "avg_spend_per_trip_2025",
                "type": "quantitative",
                "title": "Average spend per trip",
                "format": "$,.0f"
              },
              {
                "field": "selected_value",
                "type": "quantitative",
                "title": "Selected value",
                "format": ",.1f"
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {"state": "New South Wales", "abbr": "NSW", "lon": 146.5, "lat": -32.8},
              {"state": "Victoria", "abbr": "VIC", "lon": 144.5, "lat": -36.9},
              {"state": "Queensland", "abbr": "QLD", "lon": 143.5, "lat": -22.5},
              {"state": "South Australia", "abbr": "SA", "lon": 135.5, "lat": -30.8},
              {"state": "Western Australia", "abbr": "WA", "lon": 121.0, "lat": -25.5},
              {"state": "Tasmania", "abbr": "TAS", "lon": 147.0, "lat": -41.8},
              {"state": "Northern Territory", "abbr": "NT", "lon": 134.0, "lat": -20.5},
              {"state": "Australian Capital Territory", "abbr": "ACT", "lon": 149.2, "lat": -35.7}
            ]
          },
          "transform": [
            {
              "lookup": "state",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number",
                      "exp_change_pct": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": "isValid(datum.expenditure_2025_m)"
            },
            {
              "calculate": "(datum.trips_2025 - datum.trips_2024) / datum.trips_2024 * 100",
              "as": "trips_change_pct"
            },
            {
              "calculate": "selectedView == '% change expenditure' ? datum.abbr + ' ' + format(datum.exp_change_pct, '+.1f') + '%' : (selectedView == '2024 expenditure' ? datum.abbr + ' $' + format(datum.expenditure_2024_m, ',.0f') + 'M' : (selectedView == '2025 expenditure' ? datum.abbr + ' $' + format(datum.expenditure_2025_m, ',.0f') + 'M' : (selectedView == '2024 visitor trips' ? datum.abbr + ' ' + format(datum.trips_2024, ',.0f') + 'k' : datum.abbr + ' ' + format(datum.trips_2025, ',.0f') + 'k')))",
              "as": "label_text"
            }
          ],
          "mark": {
            "type": "text",
            "fontSize": 10,
            "fontWeight": "normal",
            "font": "Arial",
            "stroke": "#111827",
            "strokeWidth": 1.1,
            "strokeOpacity": 0.55,
            "dx": 0,
            "dy": 0
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label_text",
              "type": "nominal"
            },
            "color": {
              "value": "#ffffff"
            },
            "opacity": {
              "value": 0.97
            }
          }
        }
      ]
    },
    {
      "hconcat": [
        {
          "title": {
            "text": "Selected State/Territory",
            "anchor": "start",
            "font": "Arial",
            "fontSize": 14
          },
          "width": 280,
          "height": 220,
          "projection": {
            "type": "mercator"
          },
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "lookup": "state_name",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number",
                      "exp_change_pct": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": {
                "param": "stateSelection",
                "empty": false
              }
            },
            {
              "calculate": "selectedView == '% change expenditure' ? datum.exp_change_pct : (selectedView == '2024 expenditure' ? datum.expenditure_2024_m : (selectedView == '2025 expenditure' ? datum.expenditure_2025_m : (selectedView == '2024 visitor trips' ? datum.trips_2024 : datum.trips_2025)))",
              "as": "selected_value"
            },
            {
              "calculate": "selectedView == '% change expenditure' ? (datum.selected_value < 0 ? '#e66101' : (datum.selected_value < 10 ? '#b8b8b8' : (datum.selected_value < 20 ? '#67a9cf' : '#2166ac'))) : (selectedView == '2024 expenditure' || selectedView == '2025 expenditure' ? (datum.selected_value < 1500 ? '#dbeafe' : (datum.selected_value < 4000 ? '#93c5fd' : (datum.selected_value < 8000 ? '#3b82f6' : '#1e3a8a'))) : (datum.selected_value < 500 ? '#ede9fe' : (datum.selected_value < 1500 ? '#c4b5fd' : (datum.selected_value < 3000 ? '#8b5cf6' : '#4c1d95'))))",
              "as": "map_color"
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "#111827",
            "strokeWidth": 1.5
          },
          "encoding": {
            "color": {
              "field": "map_color",
              "type": "nominal",
              "scale": null,
              "legend": null
            },
            "tooltip": [
              {
                "field": "state_name",
                "type": "nominal",
                "title": "State/Territory"
              },
              {
                "field": "selected_value",
                "type": "quantitative",
                "title": "Selected value",
                "format": ",.1f"
              }
            ]
          }
        },
        {
          "title": {
            "text": "Selected Value",
            "anchor": "start",
            "font": "Arial",
            "fontSize": 14
          },
          "width": 480,
          "height": 120,
          "data": {
            "url": "data/australia_states.topojson",
            "format": {
              "type": "topojson",
              "feature": "STE11aAust"
            }
          },
          "transform": [
            {
              "calculate": "datum.properties.STATE_NAME",
              "as": "state_name"
            },
            {
              "lookup": "state_name",
              "from": {
                "data": {
                  "url": "data/state_expenditure.csv",
                  "format": {
                    "type": "csv",
                    "parse": {
                      "trips_2024": "number",
                      "trips_2025": "number",
                      "expenditure_2024_m": "number",
                      "expenditure_2025_m": "number",
                      "exp_change_pct": "number"
                    }
                  }
                },
                "key": "state",
                "fields": [
                  "trips_2024",
                  "trips_2025",
                  "expenditure_2024_m",
                  "expenditure_2025_m",
                  "exp_change_pct"
                ]
              }
            },
            {
              "filter": {
                "param": "stateSelection",
                "empty": false
              }
            },
            {
              "calculate": "selectedView == '% change expenditure' ? datum.exp_change_pct : (selectedView == '2024 expenditure' ? datum.expenditure_2024_m : (selectedView == '2025 expenditure' ? datum.expenditure_2025_m : (selectedView == '2024 visitor trips' ? datum.trips_2024 : datum.trips_2025)))",
              "as": "selected_value"
            },
            {
              "calculate": "selectedView",
              "as": "metric_label"
            }
          ],
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 2
          },
          "encoding": {
            "x": {
              "field": "selected_value",
              "type": "quantitative",
              "title": null,
              "axis": {
                "format": ",.0f"
              }
            },
            "y": {
              "field": "state_name",
              "type": "nominal",
              "title": null
            },
            "color": {
              "value": "#2563eb"
            },
            "tooltip": [
              {
                "field": "state_name",
                "type": "nominal",
                "title": "State/Territory"
              },
              {
                "field": "metric_label",
                "type": "nominal",
                "title": "View"
              },
              {
                "field": "selected_value",
                "type": "quantitative",
                "title": "Value",
                "format": ",.1f"
              }
            ]
          }
        }
      ],
      "spacing": 40
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "gradientLength": 220,
      "titleColor": "#1e293b",
      "labelColor": "#1e293b"
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    }
  }
}
