{
  "width": 980,
  "height": 420,
  "background": "#ffffff",
  "title": {
    "text": "Capital city and regional share",
    "anchor": "middle",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "params": [
    {
      "name": "selectedMeasure",
      "value": "Nights",
      "bind": {
        "input": "select",
        "options": [
          "Trips",
          "Nights",
          "Expenditure"
        ],
        "name": "Measure: "
      }
    }
  ],
  "data": {
    "url": "data/capital_regional.csv"
  },
  "transform": [
    {
      "filter": "datum.measure == selectedMeasure"
    }
  ],
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "title": null,
      "sort": {
        "field": "value_2025",
        "op": "sum",
        "order": "descending"
      }
    },
    "x": {
      "field": "value_2025",
      "type": "quantitative",
      "aggregate": "sum",
      "stack": "normalize",
      "title": "Share of selected 2025 measure",
      "axis": {
        "format": ".0%",
        "gridColor": "#e5edf3",
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    },
    "color": {
      "field": "area_type",
      "type": "nominal",
      "title": "Area type",
      "scale": {
        "domain": [
          "Capital city / gateway",
          "Regional area"
        ],
        "range": [
          "#6a51a3",
          "#e69f00"
        ]
      }
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State/Territory"
      },
      {
        "field": "area",
        "type": "nominal",
        "title": "Area"
      },
      {
        "field": "area_type",
        "type": "nominal",
        "title": "Area type"
      },
      {
        "field": "measure",
        "type": "nominal",
        "title": "Measure"
      },
      {
        "field": "value_2025",
        "type": "quantitative",
        "title": "2025 value",
        "format": ",.1f"
      },
      {
        "field": "share_pct",
        "type": "quantitative",
        "title": "Share within state",
        "format": ".1f"
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "height": {
          "band": 0.74
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.state == 'Australian Capital Territory' && datum.area_type == 'Capital city / gateway'"
        }
      ],
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "font": "Arial",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#ffffff"
      },
      "encoding": {
        "x": {
          "datum": 0.5,
          "type": "quantitative"
        },
        "y": {
          "field": "state",
          "type": "nominal",
          "sort": {
            "field": "value_2025",
            "op": "sum",
            "order": "descending"
          }
        },
        "text": {
          "value": "ACT: fully capital/gateway"
        },
        "color": {
          "value": "#ffffff"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelLimit": 240,
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}
