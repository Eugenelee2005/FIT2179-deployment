{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 980,
  "height": 520,
  "background": "#ffffff",
  "title": {
    "text": "Top tourism regions by visitor nights",
    "subtitle": "The longest lollipops show where international visitors spent the most nights.",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "data": {
    "url": "data/top_regions.csv"
  },
  "transform": [
    {
      "filter": "datum.rank <= 15"
    },
    {
      "calculate": "0",
      "as": "zero"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#9ecae1",
        "strokeWidth": 3
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "nights_2025",
            "order": "descending"
          }
        },
        "x": {
          "field": "zero",
          "type": "quantitative",
          "title": "2025 visitor nights ('000)"
        },
        "x2": {
          "field": "nights_2025"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 100,
        "color": "#0072b2",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "nights_2025",
            "order": "descending"
          },
          "axis": {
            "labelLimit": 260,
            "labelFontSize": 13
          }
        },
        "x": {
          "field": "nights_2025",
          "type": "quantitative",
          "title": "2025 visitor nights ('000)",
          "scale": {
            "domain": [
              0,
              100000
            ]
          },
          "axis": {
            "format": ",.0f",
            "gridColor": "#e5edf3",
            "labelFontSize": 13,
            "titleFontSize": 13
          }
        },
        "tooltip": [
          {
            "field": "region",
            "type": "nominal",
            "title": "Tourism region"
          },
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "trips_2025",
            "type": "quantitative",
            "title": "2025 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "nights_2025",
            "type": "quantitative",
            "title": "2025 nights ('000)",
            "format": ",.0f"
          },
          {
            "field": "expenditure_2025_m",
            "type": "quantitative",
            "title": "2025 expenditure ($M)",
            "format": "$,.0f"
          },
          {
            "field": "avg_nights_per_trip",
            "type": "quantitative",
            "title": "Average nights per trip",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.rank == 1"
        },
        {
          "calculate": "'Sydney: top region'",
          "as": "annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 12,
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#102033"
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "nights_2025",
            "order": "descending"
          }
        },
        "x": {
          "field": "nights_2025",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              100000
            ]
          }
        },
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelLimit": 260,
      "labelFontSize": 13,
      "titleFontSize": 13
    }
  }
}
