{
  "width": 1040,
  "height": 560,
  "background": "#ffffff",
  "title": {
    "text": "Top 10 tourism regions by visitor nights",
    "subtitle": "Use the selector to compare top tourism regions by visitor nights in 2024 and 2025.",
    "anchor": "middle",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "params": [
    {
      "name": "selectedYear",
      "value": 2025,
      "bind": {
        "input": "select",
        "options": [
          2024,
          2025
        ],
        "name": "Year: "
      }
    }
  ],
  "data": {
    "url": "data/top_regions.csv"
  },
  "transform": [
    {
      "calculate": "selectedYear == 2024 ? datum.trips_2024 : datum.trips_2025",
      "as": "selected_trips"
    },
    {
      "calculate": "selectedYear == 2024 ? datum.nights_2024 : datum.nights_2025",
      "as": "selected_nights"
    },
    {
      "calculate": "selectedYear == 2024 ? datum.expenditure_2024_m : datum.expenditure_2025_m",
      "as": "selected_expenditure_m"
    },
    {
      "calculate": "datum.selected_nights / datum.selected_trips",
      "as": "selected_avg_nights_per_trip"
    },
    {
      "calculate": "selectedYear == 2024 ? '2024' : '2025'",
      "as": "selected_year_label"
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "selected_rank"
        }
      ],
      "sort": [
        {
          "field": "selected_nights",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.selected_rank <= 10"
    },
    {
      "calculate": "0",
      "as": "zero"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "stroke": "#b2abd2",
        "strokeWidth": 4
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "selected_rank",
            "order": "ascending"
          }
        },
        "x": {
          "field": "zero",
          "type": "quantitative",
          "title": "2025 visitor nights ('000)"
        },
        "x2": {
          "field": "selected_nights"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 150,
        "color": "#6a51a3",
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "selected_rank",
            "order": "ascending"
          },
          "axis": {
            "labelLimit": 260,
            "labelFontSize": 14
          }
        },
        "x": {
          "field": "selected_nights",
          "type": "quantitative",
          "title": "Selected-year visitor nights ('000)",
          "scale": {
            "domain": [
              0,
              105000
            ]
          },
          "axis": {
            "format": ",.0f",
            "gridColor": "#e5edf3",
            "labelFontSize": 13,
            "titleFontSize": 14
          }
        },
        "tooltip": [
          {
            "field": "selected_year_label",
            "type": "nominal",
            "title": "Selected year"
          },
          {
            "field": "region",
            "type": "nominal",
            "title": "Tourism region"
          },
          {
            "field": "state",
            "type": "nominal",
            "title": "State/Territory"
          },
          {
            "field": "selected_trips",
            "type": "quantitative",
            "title": "Selected-year trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "selected_nights",
            "type": "quantitative",
            "title": "Selected-year nights ('000)",
            "format": ",.0f"
          },
          {
            "field": "selected_expenditure_m",
            "type": "quantitative",
            "title": "Selected-year expenditure ($M)",
            "format": "$,.0f"
          },
          {
            "field": "selected_avg_nights_per_trip",
            "type": "quantitative",
            "title": "Average nights per trip",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.selected_rank == 1"
        },
        {
          "calculate": "datum.region + ': top region'",
          "as": "annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 12,
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#102033"
      },
      "encoding": {
        "y": {
          "field": "region",
          "type": "nominal",
          "title": null,
          "sort": {
            "field": "selected_rank",
            "order": "ascending"
          }
        },
        "x": {
          "field": "selected_nights",
          "type": "quantitative",
          "scale": {
            "domain": [
              0,
              105000
            ]
          }
        },
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelLimit": 260,
      "labelFontSize": 14,
      "titleFontSize": 14
    }
  }
}
