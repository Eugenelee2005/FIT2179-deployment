{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 980,
  "height": 500,
  "background": "#ffffff",
  "title": {
    "text": "Source countries: visitor trips versus spending",
    "subtitle": "Bubble size shows visitor nights; colour shows visitor-trip growth from 2024 to 2025.",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "data": {
    "url": "data/source_countries.csv"
  },
  "encoding": {
    "x": {
      "field": "trips_2025",
      "type": "quantitative",
      "title": "2025 visitor trips ('000)",
      "axis": {
        "format": ",.0f",
        "gridColor": "#e5edf3",
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    },
    "y": {
      "field": "spend_2025_m",
      "type": "quantitative",
      "title": "2025 spend in Australia ($M)",
      "axis": {
        "format": "$,.0f",
        "gridColor": "#e5edf3",
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "circle",
        "opacity": 0.78,
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "size": {
          "field": "nights_2025",
          "type": "quantitative",
          "title": "2025 visitor nights ('000)",
          "scale": {
            "range": [
              80,
              2500
            ]
          },
          "legend": {
            "title": "Nights ('000)"
          }
        },
        "color": {
          "field": "trips_change_pct",
          "type": "quantitative",
          "title": "Trips change (%)",
          "scale": {
            "domainMid": 0,
            "range": [
              "#d95f02",
              "#f7f7f7",
              "#0072b2"
            ]
          },
          "legend": {
            "title": "Trip change 2024-2025"
          }
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "trips_2024",
            "type": "quantitative",
            "title": "2024 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "trips_2025",
            "type": "quantitative",
            "title": "2025 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "spend_2025_m",
            "type": "quantitative",
            "title": "2025 spend ($M)",
            "format": "$,.0f"
          },
          {
            "field": "nights_2025",
            "type": "quantitative",
            "title": "2025 nights ('000)",
            "format": ",.0f"
          },
          {
            "field": "trips_change_pct",
            "type": "quantitative",
            "title": "Trips change",
            "format": "+.1f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.country == 'China'"
        },
        {
          "calculate": "'China: highest spend and nights'",
          "as": "annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 16,
        "dy": -16,
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#102033"
      },
      "encoding": {
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}
