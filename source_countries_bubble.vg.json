{
  "width": 980,
  "height": 500,
  "background": "#ffffff",
  "title": {
    "text": "Source countries: selected-year visitor trips versus spending",
    "anchor": "middle",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "params": [
    {
      "name": "selectedYear",
      "value": 2025,
      "bind": {
        "input": "select",
        "options": [
          2024,
          2025
        ],
        "name": "Year: "
      }
    }
  ],
  "data": {
    "url": "data/source_countries.csv"
  },
  "transform": [
    {
      "calculate": "selectedYear == 2024 ? datum.trips_2024 : datum.trips_2025",
      "as": "selected_trips"
    },
    {
      "calculate": "selectedYear == 2024 ? datum.spend_2024_m : datum.spend_2025_m",
      "as": "selected_spend_m"
    },
    {
      "calculate": "selectedYear == 2024 ? datum.nights_2024 : datum.nights_2025",
      "as": "selected_nights"
    },
    {
      "calculate": "selectedYear == 2024 ? '2024' : '2025'",
      "as": "selected_year_label"
    }
  ],
  "encoding": {
    "x": {
      "field": "selected_trips",
      "type": "quantitative",
      "title": "Selected-year visitor trips ('000)",
      "axis": {
        "format": ",.0f",
        "gridColor": "#e5edf3",
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    },
    "y": {
      "field": "selected_spend_m",
      "type": "quantitative",
      "title": "Selected-year spend in Australia ($M)",
      "axis": {
        "format": "$,.0f",
        "gridColor": "#e5edf3",
        "labelFontSize": 12,
        "titleFontSize": 13
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "circle",
        "opacity": 0.78,
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "size": {
          "field": "selected_nights",
          "type": "quantitative",
          "title": "Selected-year visitor nights ('000)",
          "scale": {
            "range": [
              80,
              2500
            ]
          },
          "legend": {
            "title": "Nights ('000)"
          }
        },
        "color": {
          "field": "region",
          "type": "nominal",
          "title": "Source region",
          "scale": {
            "domain": [
              "Asia",
              "Europe",
              "North America",
              "Oceania"
            ],
            "range": [
              "#0072b2",
              "#cc79a7",
              "#e69f00",
              "#999999"
            ]
          },
          "legend": {
            "title": "Source region"
          }
        },
        "order": {
          "field": "selected_nights",
          "type": "quantitative",
          "sort": "descending"
        },
        "tooltip": [
          {
            "field": "selected_year_label",
            "type": "nominal",
            "title": "Selected year"
          },
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "selected_trips",
            "type": "quantitative",
            "title": "Selected-year trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "selected_spend_m",
            "type": "quantitative",
            "title": "Selected-year spend ($M)",
            "format": "$,.0f"
          },
          {
            "field": "selected_nights",
            "type": "quantitative",
            "title": "Selected-year nights ('000)",
            "format": ",.0f"
          },
          {
            "field": "trips_2024",
            "type": "quantitative",
            "title": "2024 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "trips_2025",
            "type": "quantitative",
            "title": "2025 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "spend_2025_m",
            "type": "quantitative",
            "title": "2025 spend ($M)",
            "format": "$,.0f"
          },
          {
            "field": "nights_2025",
            "type": "quantitative",
            "title": "2025 nights ('000)",
            "format": ",.0f"
          },
          {
            "field": "region",
            "type": "nominal",
            "title": "Source region"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.country == 'China'"
        },
        {
          "calculate": "'China: highest spend and nights'",
          "as": "annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 16,
        "dy": -16,
        "font": "Arial",
        "fontSize": 13,
        "fontWeight": "bold",
        "color": "#102033"
      },
      "encoding": {
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}
