{
  "width": 1040,
  "height": 520,
  "background": "#ffffff",
  "title": {
    "text": "Spending category by travel purpose",
    "anchor": "middle",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "data": {
    "url": "data/spending_by_purpose.csv"
  },
  "transform": [
    {
      "filter": "datum.expenditure_2025_m != null && isValid(datum.expenditure_2025_m)"
    }
  ],
  "encoding": {
    "x": {
      "field": "purpose",
      "type": "nominal",
      "title": "Travel purpose",
      "sort": [
        "Holiday",
        "Education",
        "Visiting friends and relatives",
        "Other / employment",
        "Business"
      ],
      "axis": {
        "labelAngle": -20,
        "labelLimit": 360,
        "labelFontSize": 14,
        "titleFontSize": 15
      }
    },
    "y": {
      "field": "spending_category",
      "type": "nominal",
      "title": "Spending category",
      "sort": [
        "Food, drink & accommodation",
        "Airfares",
        "Education",
        "Shopping",
        "Tours",
        "Transportation",
        "Other Expenditure",
        "Entertainment"
      ],
      "axis": {
        "labelLimit": 320,
        "labelFontSize": 14,
        "titleFontSize": 15
      }
    },
    "color": {
      "field": "expenditure_2025_m",
      "type": "quantitative",
      "title": "Expenditure ($M)",
      "scale": {
        "range": [
          "#f2f0f7",
          "#cbc9e2",
          "#9e9ac8",
          "#6a51a3"
        ]
      },
      "legend": {
        "format": "$,.0f",
        "labelFontSize": 14,
        "titleFontSize": 15
      }
    },
    "tooltip": [
      {
        "field": "purpose",
        "type": "nominal",
        "title": "Travel purpose"
      },
      {
        "field": "spending_category",
        "type": "nominal",
        "title": "Spending category"
      },
      {
        "field": "expenditure_2025_m",
        "type": "quantitative",
        "title": "Expenditure ($M)",
        "format": "$,.0f"
      },
      {
        "field": "share_within_purpose_pct",
        "type": "quantitative",
        "title": "Share of purpose spend",
        "format": ".1f"
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "rect",
        "stroke": "#ffffff",
        "strokeWidth": 1
      }
    },
    {
      "transform": [
        {
          "filter": "datum.spending_category == 'Education' && datum.purpose == 'Education'"
        }
      ],
      "mark": {
        "type": "text",
        "font": "Arial",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#ffffff"
      },
      "encoding": {
        "text": {
          "value": "Highest cell"
        },
        "color": {
          "value": "#ffffff"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 14,
      "titleFontSize": 15
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 14,
      "titleFontSize": 15
    }
  }
}
