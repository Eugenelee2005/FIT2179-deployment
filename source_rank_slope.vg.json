{
  "width": 760,
  "height": 520,
  "padding": {
    "left": 190,
    "right": 190,
    "top": 18,
    "bottom": 16
  },
  "background": "#ffffff",
  "title": {
    "text": "Source country rank change",
    "anchor": "middle",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "data": {
    "url": "data/source_country_ranks.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2,
        "opacity": 0.78
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null,
          "axis": {
            "labelAngle": 0,
            "labelFontWeight": "bold",
            "labelFontSize": 13
          }
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "title": "Rank by visitor trips",
          "scale": {
            "reverse": true,
            "domain": [
              0.5,
              12.5
            ]
          },
          "axis": {
            "tickMinStep": 1,
            "labelFontSize": 13,
            "titleFontSize": 13
          }
        },
        "detail": {
          "field": "country",
          "type": "nominal"
        },
        "color": {
          "field": "rank_change",
          "type": "quantitative",
          "title": "Rank change",
          "scale": {
            "domainMid": 0,
            "range": [
              "#d95f02",
              "#c7c7c7",
              "#0072b2"
            ]
          }
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 90,
        "stroke": "#ffffff",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {
            "reverse": true,
            "domain": [
              0.5,
              12.5
            ]
          }
        },
        "color": {
          "field": "rank_change",
          "type": "quantitative",
          "legend": null,
          "scale": {
            "domainMid": 0,
            "range": [
              "#d95f02",
              "#c7c7c7",
              "#0072b2"
            ]
          }
        },
        "tooltip": [
          {
            "field": "country",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "trips_2024",
            "type": "quantitative",
            "title": "2024 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "trips_2025",
            "type": "quantitative",
            "title": "2025 trips ('000)",
            "format": ",.1f"
          },
          {
            "field": "rank_2024",
            "type": "quantitative",
            "title": "2024 rank"
          },
          {
            "field": "rank_2025",
            "type": "quantitative",
            "title": "2025 rank"
          },
          {
            "field": "rank_change",
            "type": "quantitative",
            "title": "Rank movement"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2024"
        }
      ],
      "mark": {
        "type": "text",
        "align": "right",
        "baseline": "middle",
        "dx": -10,
        "font": "Arial",
        "fontSize": 13,
        "color": "#17212b"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {
            "reverse": true,
            "domain": [
              0.5,
              12.5
            ]
          }
        },
        "text": {
          "field": "country",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2025"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 10,
        "font": "Arial",
        "fontSize": 13,
        "color": "#17212b"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {
            "reverse": true,
            "domain": [
              0.5,
              12.5
            ]
          }
        },
        "text": {
          "field": "country",
          "type": "nominal"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.country == 'United Kingdom' && datum.year == 2025"
        },
        {
          "calculate": "'UK moved ahead of USA'",
          "as": "annotation"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 86,
        "dy": -10,
        "font": "Arial",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#0072b2"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "scale": {
            "reverse": true,
            "domain": [
              0.5,
              12.5
            ]
          }
        },
        "text": {
          "field": "annotation",
          "type": "nominal"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 13,
      "titleFontSize": 13
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}
