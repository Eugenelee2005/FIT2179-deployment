{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 980,
  "height": 620,
  "background": "#ffffff",
  "title": {
    "text": "Average nights per trip by source country",
    "subtitle": "Longer bars indicate source markets whose visitors stayed longer on average.",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 10
  },
  "data": {
    "url": "data/source_countries.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusTopRight": 2,
    "cornerRadiusBottomRight": 2
  },
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "title": null,
      "sort": "-x",
      "axis": {
        "labelLimit": 240,
        "labelFontSize": 13
      }
    },
    "x": {
      "field": "avg_nights_per_trip_2025",
      "type": "quantitative",
      "title": "Average nights per trip",
      "axis": {
        "format": ".0f",
        "gridColor": "#e5edf3",
        "labelFontSize": 13,
        "titleFontSize": 13
      }
    },
    "color": {
      "field": "avg_nights_per_trip_2025",
      "type": "quantitative",
      "legend": null,
      "scale": {
        "range": [
          "#deebf7",
          "#9ecae1",
          "#3182bd",
          "#08519c"
        ]
      }
    },
    "tooltip": [
      {
        "field": "country",
        "type": "nominal",
        "title": "Country"
      },
      {
        "field": "trips_2025",
        "type": "quantitative",
        "title": "2025 trips ('000)",
        "format": ",.1f"
      },
      {
        "field": "nights_2025",
        "type": "quantitative",
        "title": "2025 nights ('000)",
        "format": ",.0f"
      },
      {
        "field": "avg_nights_per_trip_2025",
        "type": "quantitative",
        "title": "Average nights per trip",
        "format": ".1f"
      },
      {
        "field": "spend_2025_m",
        "type": "quantitative",
        "title": "2025 expenditure ($M)",
        "format": "$,.0f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 13,
      "titleFontSize": 13
    }
  }
}
