{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 760,
  "height": 500,
  "background": "#ffffff",
  "title": {
    "text": "Which visitors stay the longest?",
    "subtitle": "Average nights per trip shows how long visitors from each source market tend to remain in Australia.",
    "anchor": "start",
    "font": "Arial",
    "fontSize": 20,
    "subtitleFontSize": 12,
    "subtitleColor": "#5c6876",
    "offset": 12
  },
  "data": {
    "url": "data/source_countries.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusTopRight": 2,
    "cornerRadiusBottomRight": 2
  },
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "title": null,
      "sort": "-x",
      "axis": {
        "labelLimit": 180
      }
    },
    "x": {
      "field": "avg_nights_per_trip_2025",
      "type": "quantitative",
      "title": "Average nights per trip",
      "axis": {
        "format": ".0f",
        "gridColor": "#e5edf3"
      }
    },
    "color": {
      "field": "avg_nights_per_trip_2025",
      "type": "quantitative",
      "legend": null,
      "scale": {
        "range": ["#deebf7", "#9ecae1", "#3182bd", "#08519c"]
      }
    },
    "tooltip": [
      {
        "field": "country",
        "type": "nominal",
        "title": "Country"
      },
      {
        "field": "trips_2025",
        "type": "quantitative",
        "title": "2025 trips ('000)",
        "format": ",.1f"
      },
      {
        "field": "nights_2025",
        "type": "quantitative",
        "title": "2025 nights ('000)",
        "format": ",.0f"
      },
      {
        "field": "avg_nights_per_trip_2025",
        "type": "quantitative",
        "title": "Average nights per trip",
        "format": ".1f"
      },
      {
        "field": "spend_2025_m",
        "type": "quantitative",
        "title": "2025 expenditure ($M)",
        "format": "$,.0f"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial"
    }
  }
}
